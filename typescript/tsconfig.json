{
  "compilerOptions": {
    "alwaysStrict": true,
    "allowImportingTsExtensions": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": ["ESNext"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "outDir": "dist",
    "rootDir": ".",
    "sourceMap": true,
    "strict": true,
    "strictFunctionTypes": true,
    "target": "ES2020",
    "types": []
  },
  "exclude": ["dist", "node_modules", "**/*.test.ts"]
}
